# Copy to .env and fill in.

# --- Gmail SMTP (free, 500 emails/day per account) ---
# Create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.address@gmail.com
SMTP_PASS=your-16-char-app-password
SENDER_NAME=Louis from After5
REPLY_TO=louis@after5digital.com

# --- Ollama (local, free) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Slack incoming webhook (free) ---
# https://api.slack.com/messaging/webhooks  — leave blank to log to console
SLACK_WEBHOOK_URL=

# --- Meta Ad Library (free, official) ---
# https://www.facebook.com/ads/library/api/ — optional
META_AD_LIBRARY_TOKEN=

# --- Hunter.io (free tier: 25 searches/mo) ---
HUNTER_API_KEY=

# --- IMAP for reading replies (free, Gmail) ---
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# --- App password for the dashboard, if you ever expose it ---
APP_PASSWORD=change-me
